{
    "swagger": "2.0",
    "info": {
        "description": "Service for managing video content.",
        "title": "Video Service API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/v1/videos/id/{videoID}": {
            "get": {
                "description": "Returns details of a single video by its unique identifier",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "videos"
                ],
                "summary": "Get video by ID",
                "parameters": [
                    {
                        "type": "string",
                        "description": "JWT token for authentication (e.g., Bearer \u003ctoken\u003e)",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "format": "uuid",
                        "description": "video ID (UUID)",
                        "name": "videoID",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/httpadp.VideoResponseBody"
                        }
                    },
                    "400": {
                        "description": "Invalid video ID format",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/v1/videos/pub/{publisherID}": {
            "get": {
                "description": "Returns a list of videos for a specific publisher with pagination and search support",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "videos"
                ],
                "summary": "Get videos by publisher",
                "parameters": [
                    {
                        "type": "string",
                        "description": "JWT token for authentication (e.g., Bearer \u003ctoken\u003e)",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "publisher ID (UUID)",
                        "name": "publisherID",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Limit (example: 10)",
                        "name": "limit",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Offset (example: 0)",
                        "name": "offset",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Sort (example: `date`)",
                        "name": "sort",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Order (`t` for ascending, `f` for descending)",
                        "name": "order",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/httpadp.VideoResponseBody"
                            }
                        }
                    }
                }
            },
            "post": {
                "description": "Creates a new video record for the specified publisher.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "videos"
                ],
                "summary": "Creates new video.",
                "parameters": [
                    {
                        "type": "string",
                        "description": "JWT token for authentication (e.g., Bearer \u003ctoken\u003e)",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Publisher ID (UUID)",
                        "name": "publisherID",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Video creation request body",
                        "name": "video",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/httpadp.createVideoRequestBody"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created"
                    },
                    "400": {
                        "description": "Invalid input",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/v1/videos/search/": {
            "get": {
                "description": "Search videos in the entire database by a keyword",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "videos"
                ],
                "summary": "Global search",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Search query",
                        "name": "query",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Limit (example: 10)",
                        "name": "limit",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Offset (example: 0)",
                        "name": "offset",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Sort (example: `date`)",
                        "name": "sort",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Order (`t` for ascending, `f` for descending)",
                        "name": "order",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/httpadp.VideoResponseBody"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "httpadp.VideoResponseBody": {
            "type": "object",
            "properties": {
                "createdAt": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "publisherID": {
                    "type": "string"
                },
                "topic": {
                    "type": "string"
                }
            }
        },
        "httpadp.createVideoRequestBody": {
            "type": "object",
            "required": [
                "description",
                "topic"
            ],
            "properties": {
                "description": {
                    "type": "string"
                },
                "topic": {
                    "type": "string"
                }
            }
        }
    }
}