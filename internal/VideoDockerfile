FROM golang:1.25-alpine AS builder

WORKDIR /app/internal

COPY go.mod go.sum ./
RUN go mod download

WORKDIR /app
COPY . ./internal

WORKDIR /app/internal
RUN go build -o /bin/video-service ./video-service/cmd

FROM debian:bookworm-slim
WORKDIR /app
COPY --from=builder /bin/video-service ./video-service
COPY --from=builder /app/internal/config/video_config.json ./config/video_config.json

CMD ["./video-service"]
